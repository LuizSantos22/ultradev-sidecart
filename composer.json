    "type": "magento-module",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Luiz Santos",
            "email": "luiz@ultradev.com.br",
            "homepage": "https://ultraeletronicos.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=5.6",
        "magento-hackathon/magento-composer-installer": "*"
    },
    "extra": {
        "map": [
            ["app/code/community/UltraDev/SideCart", "app/code/community/UltraDev/SideCart"],
            ["app/design/frontend/base/default/layout/ultradev_sidecart.xml", "app/design/frontend/base/default/layout/ultradev_sidecart.xml"],
            ["app/design/frontend/base/default/template/ultradev/sidecart", "app/design/frontend/base/default/template/ultradev/sidecart"],
            ["app/etc/modules/UltraDev_SideCart.xml", "app/etc/modules/UltraDev_SideCart.xml"],
            ["skin/frontend/base/default/css/ultradev", "skin/frontend/base/default/css/ultradev"],
            ["skin/frontend/base/default/js/ultradev", "skin/frontend/base/default/js/ultradev"]
        ]
    }
}
