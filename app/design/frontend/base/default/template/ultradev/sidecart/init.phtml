if (!$helper->isEnabled()) return;
?>
<div id="ultradev-sidecart" class="usc-sidecart" style="display:none;">
    <div class="usc-overlay" id="usc-overlay"></div>
    <div class="usc-container" id="usc-container">
        <div class="usc-loading"><?php echo $this->__('Loading...') ?></div>
    </div>
</div>

<script type="text/template" id="usc-empty-template">
    <div class="usc-cart usc-cart--empty">
        <div class="usc-header">
            <button class="usc-close" id="usc-close" type="button"><i class="bi bi-arrow-right"></i></button>
            <div class="usc-title"><strong>MEU</strong> CARRINHO</div>
            <span></span>
        </div>
        <div class="usc-empty-msg">
            <p><?php echo $this->__('Your cart is empty.') ?></p>
            <a href="<?php echo $this->getUrl() ?>"><?php echo $this->__('Continue Shopping') ?></a>
        </div>
    </div>
</script>

<script type="text/javascript">
    window.UltraDevSideCartConfig = {
        cartUrl: '<?php echo Mage::getUrl('ultradev_sidecart/cart/index') ?>',
        addToCartSelector: '<?php echo $helper->getAddToCartSelector() ?>',
        cartLinkSelector: '<?php echo $helper->getCartSelector() ?>',
        updateItemUrl: '<?php echo Mage::getUrl('ultradev_sidecart/cart/updateItem') ?>',
        removeItemUrl: '<?php echo Mage::getUrl('ultradev_sidecart/cart/removeItem') ?>',
        applyCouponUrl: '<?php echo Mage::getUrl('ultradev_sidecart/cart/applyCoupon') ?>',
