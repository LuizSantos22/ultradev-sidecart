<?xml version="1.0"?>
<config>
    <sections>
        <ultradev_sidecart translate="label" module="ultradev_sidecart">
            <label>UltraDev SideCart</label>
            <tab>general</tab>
            <sort_order>999</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>
            <groups>
                <general translate="label">
                    <label>General Settings</label>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Enable SideCart</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <cart_selector translate="label">
                            <label>Cart Link Selector (jQuery)</label>
                            <comment>Ex: .top-link-cart, .header-minicart .cart-link</comment>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </cart_selector>
                        <addtocart_selector translate="label">
                            <label>Add to Cart Button Selector (jQuery)</label>
                            <comment>Ex: .btn-cart, .actions .btn-cart</comment>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </addtocart_selector>
                    </fields>
                </general>
            </groups>
        </ultradev_sidecart>
    </sections>
</config>
